rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Anyone logged in can read any user (needed for leaderboard)
      allow read: if request.auth != null;
      // User can create their own doc on signup
      allow create: if request.auth != null
                    && request.auth.token.email == userId + '@smithlegacy.app';
      // User can update their own doc (claims, smithcoins, daily reward, unlocks)
      allow update: if request.auth != null
                    && request.auth.token.email == userId + '@smithlegacy.app';
      // Mods can update any user doc (verify/deny claims, award SC)
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.token.email.split('@')[0])).data.isMod == true;
      // Mods can delete users (server reset)
      allow delete: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.token.email.split('@')[0])).data.isMod == true;
    }

    // Claims collection (pending achievement claims)
    match /claims/{claimId} {
      allow read: if request.auth != null;
      // Any logged-in user can create a claim
      allow create: if request.auth != null;
      // Mods can delete claims (verify/deny)
      allow delete: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.token.email.split('@')[0])).data.isMod == true;
    }

    // First earners
    match /firstEarners/{achId} {
      allow read: if request.auth != null;
      // Mods can create/delete first earners
      allow create, delete: if request.auth != null
                            && get(/databases/$(database)/documents/users/$(request.auth.token.email.split('@')[0])).data.isMod == true;
    }

    // Announcements
    match /announcements/{docId} {
      allow read: if request.auth != null;
      // Mods can create/update/delete announcements
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.token.email.split('@')[0])).data.isMod == true;
    }

    // Daily Achievement
    match /dailyAchievement/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.token.email.split('@')[0])).data.isMod == true;
    }

    // Suggestions
    match /suggestions/{sugId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.token.email.split('@')[0])).data.isMod == true;
    }
  }
}
